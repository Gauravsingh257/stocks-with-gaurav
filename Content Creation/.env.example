# Content Creation — Environment Variables
# Copy this file to .env and fill in your values

# ── Instagram (Meta Graph API) ────────────────────────────────────────────
# Get from: https://developers.facebook.com/apps/ → Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ID=

# ── Telegram (fallback publishing) ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CONTENT_CHAT_ID=

# ── OpenAI (optional — for content enrichment) ───────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── News APIs ─────────────────────────────────────────────────────────────
# NewsAPI: https://newsapi.org/register
NEWS_API_KEY=

# GNews: https://gnews.io/
GNEWS_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────────
CONTENT_LOG_LEVEL=INFO
