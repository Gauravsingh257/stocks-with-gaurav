# =============================================================================
# Trading Algo — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- Zerodha / Kite Connect ---
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_ACCESS_TOKEN=

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
SMC_PRO_CHAT_ID=your_pro_chat_id_here

# --- OpenAI (for AI agents) ---
OPENAI_API_KEY=your_openai_key_here

# --- Database ---
DATABASE_URL=sqlite:///dashboard.db
BACKTEST_DB_URL=sqlite:///backtest_data.db

# --- Trading Config ---
ENGINE_MODE=AGGRESSIVE
BACKTEST_MODE=0
DEBUG_MODE=1
PAPER_TRADING=1

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=logs

# =============================================================================
# Content Engine (content_engine/) - isolated from intraday trading pipeline
# =============================================================================

# Telegram: separate channel for content (NOT the signal channel)
TELEGRAM_CONTENT_CHAT_ID=your_content_channel_id_here

# OpenAI model for content generation (key reused from above)
OPENAI_MODEL=gpt-4o-mini

# News APIs (at least one recommended for news_agent)
NEWS_API_KEY=your_newsapi_org_key_here
GNEWS_API_KEY=your_gnews_io_key_here

# Log level for content engine
CONTENT_LOG_LEVEL=INFO
